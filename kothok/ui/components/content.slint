import { Row } from "../types.slint";

export component ContentArea inherits Rectangle {
    in property <[Row]> rows;
    in property <int> page;
    in property <int> page-count;
    in property <int> saved-page: 0;
    in property <bool> playing: false;
    in property <bool> play-enabled: false;
    in property <string> status: "";
    in property <bool> nav-recent: false;
    in property <bool> picker-active: false;
    in property <color> brand-green: #006A4E;
    in property <color> brand-red: #E00000;
    in property <color> brand-gray: #8a8a8a;

    callback play-pause-toggle();
    callback progress-tap(float);

    VerticalLayout {
        padding-left: 56px; padding-right: 56px;
        padding-top: 32px; padding-bottom: 0px;
        spacing: 0px;
        vertical-stretch: 1;

        for row in root.rows : Rectangle {
            height: row.kind == 2 ? 84px : ((row.kind == 1 || row.kind == 3) ? row.tag * 1px : 38px);
            VerticalLayout {
                y: 0; height: 100%;
                spacing: 0px;
                HorizontalLayout {
                    spacing: 0px;
                    vertical-stretch: 1;
                    Rectangle { width: 24px; }
                    Text {
                        text: row.text;
                        color: transparent;
                        font-size: row.kind == 2 ? 60px : 36px;
                        vertical-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }

    Rectangle {
        y: root.height - 92px;
        height: 70px;
        width: root.width;
        background: #ffffff;

        Rectangle {
            height: 10px;
            y: 12px;
            x: 56px;
            width: root.width - 200px;
            background: #d0d0d0;
            border-radius: 5px;

            Rectangle {
                x: 0px;
                height: 10px;
                width: root.page-count > 0 ? (root.page + 1) * (root.width - 200px) / root.page-count : 0px;
                background: #111111;
                border-radius: 5px;
            }

            Rectangle {
                x: root.page-count > 0 ? (root.page + 1) * (root.width - 200px) / root.page-count - 12px : -12px;
                y: -7px;
                width: 24px;
                height: 24px;
                background: #111111;
                border-radius: 12px;
                border-width: 3px;
                border-color: #ffffff;
                visible: root.page-count > 0;
            }

            Rectangle {
                x: root.page-count > 0 ? (root.saved-page + 1) * (root.width - 200px) / root.page-count - 7px : 0px;
                y: -30px;
                width: 14px;
                height: 30px;
                background: #000000;
                border-width: 2px;
                border-color: #ffffff;
                border-radius: 2px;
                visible: root.page-count > 0;
            }

            pbar := TouchArea {
                height: 32px; y: -10px;
                mouse-cursor: none;
                clicked => { root.progress-tap(pbar.mouse-x / pbar.width); }
            }
        }

        Text {
            text: root.status != ""
                  ? root.status
                  : ((root.playing || root.nav-recent)
                     ? ("Page " + (root.page + 1) + " of " + root.page-count)
                     : (root.play-enabled
? "Swipe down: menu - double-tap: play - swipe: pages"
                         : "Connect WiFi & Bluetooth to play - swipe down: menu"));
            color: #111111;
            font-size: 22px;
            horizontal-alignment: center;
            vertical-alignment: center;
            y: 32px;
            x: 56px;
            width: root.width - 200px;
            wrap: no-wrap;
            overflow: elide;
            padding-left: 20px;
            padding-right: 20px;
            visible: !root.picker-active && root.page-count > 0;
        }

        Rectangle {
            x: root.width - 88px;
            y: 3px;
            width: 64px;
            height: 64px;
            border-radius: 32px;
            background: !root.play-enabled ? root.brand-gray
                        : (root.playing ? root.brand-red : root.brand-green);
            visible: !root.picker-active && root.page-count > 0;
            pp-touch := TouchArea {
                clicked => {
                    if (root.play-enabled) { root.play-pause-toggle(); }
                }
            }

            Rectangle {
                visible: root.playing;
                x: 22px; y: 19px; width: 7px; height: 26px;
                background: #ffffff; border-radius: 2px;
            }
            Rectangle {
                visible: root.playing;
                x: 35px; y: 19px; width: 7px; height: 26px;
                background: #ffffff; border-radius: 2px;
            }

            Rectangle { visible: !root.playing; x: 23px; y: 19px; width: 5px;  height: 5px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 23px; y: 24px; width: 11px; height: 5px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 23px; y: 29px; width: 18px; height: 5px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 23px; y: 34px; width: 11px; height: 5px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 23px; y: 39px; width: 5px;  height: 5px; background: #ffffff; }
        }
    }
}
