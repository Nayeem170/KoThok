import { Row } from "../types.slint";
import { ScrollableText } from "scrollable_text.slint";

export component ContentArea inherits Rectangle {
    in property <[Row]> rows;
    in property <int> page;
    in property <int> page-count;
    in property <int> saved-page: 0;
    in property <bool> playing: false;
    in property <bool> play-enabled: false;
    in property <string> status: "";
    in property <string> header-title: "";
    in property <image> book-title-img;
    in property <int> book-title-img-h: 0;
    in property <bool> header-visible: true;
    in property <bool> nav-recent: false;
    in property <bool> has-navigated: false;
    in property <bool> picker-active: false;
    in property <float> bookmark-frac: -1.0;
    in property <color> brand-green: #006A4E;
    in property <color> brand-red: #F42A41;
    in property <color> brand-gray: #8a8a8a;
    in property <color> text-primary: #111111;
    in property <color> text-secondary: #666666;
    in property <color> text-hint: #999999;
    in property <color> track-color: #d0d0d0;
    in property <bool> title-overflow: false;

    callback play-pause-toggle();
    callback progress-tap(float);
    callback chapters-tap();

    VerticalLayout {
        padding-left: 56px; padding-right: 56px;
        padding-top: 32px; padding-bottom: 0px;
        spacing: 0px;
        vertical-stretch: 1;

        for row in root.rows : Rectangle {
            height: row.kind == 2 ? 84px : ((row.kind == 1 || row.kind == 3) ? row.tag * 1px : 38px);
            VerticalLayout {
                y: 0; height: 100%;
                spacing: 0px;
                HorizontalLayout {
                    spacing: 0px;
                    vertical-stretch: 1;
                    Rectangle { width: 24px; }
                    Text {
                        text: row.text;
                        color: transparent;
                        font-size: row.kind == 2 ? 60px : 36px;
                        vertical-alignment: center;
                        wrap: word-wrap;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }

    Rectangle {
        y: 0px;
        height: 110px;
        width: root.width;
        background: #ffffff;
        visible: root.header-visible && !root.picker-active && root.page-count > 0;

        Rectangle {
            x: 23px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-red;
            Image {
                source: @image-url("assets/library.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        ScrollableText {
            txt: root.header-title;
            txt-color: root.text-secondary; font-size: 33px; bold: true;
            overflow: root.title-overflow;
            x: 119px; width: root.width - 686px; y: 17px; height: 76px;
            visible: root.book-title-img-h == 0;
        }

        Rectangle {
            x: root.width - 557px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/mode-toggle.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            x: root.width - 471px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/bookmark.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            x: root.width - 385px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/jump.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            x: root.width - 290px; y: 30px;
            width: 3px; height: 50px;
            background: root.track-color;
        }

        Rectangle {
            x: root.width - 271px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/sleep.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            x: root.width - 185px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/gear.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            x: root.width - 99px; y: 17px;
            width: 76px; height: 76px;
            border-radius: 38px;
            background: root.brand-green;
            Image {
                source: @image-url("assets/chapters.svg");
                image-fit: contain;
                width: 38px; height: 38px;
                x: 19px; y: 19px;
            }
        }

        Rectangle {
            y: 107px; height: 3px; width: root.width; background: root.track-color;
        }
    }

    Rectangle {
        y: root.height - 92px;
        height: 92px;
        width: root.width;
        background: #ffffff;

        Rectangle {
            height: 10px;
            y: 12px;
            x: 56px;
            width: root.width - 200px;
            background: root.brand-red;
            border-radius: 5px;

            // Fill and knob use page/page-count (start-of-page), the same
            // book-level convention as audio mode and the bookmark tick, so the
            // knob and the tick coincide when you are on the bookmarked page.
            Rectangle {
                x: 0px;
                height: 10px;
                width: root.page-count > 0 ? root.page * (root.width - 200px) / root.page-count : 0px;
                background: root.brand-green;
                border-radius: 5px;
            }

            // Same marker as audio mode: one green tab straddling the bar.
            // Declared before the knob so the knob paints on top of it.
            Rectangle {
                x: root.bookmark-frac >= 0.0 ? root.bookmark-frac * (root.width - 200px) - 7px : -400px;
                y: -13px;
                width: 15px;
                height: 36px;
                background: root.brand-green;
                border-radius: 5px;
                visible: root.bookmark-frac >= 0.0;
            }

            Rectangle {
                x: root.page-count > 0 ? root.page * (root.width - 200px) / root.page-count - 12px : -12px;
                y: -7px;
                width: 24px;
                height: 24px;
                background: #ffffff;
                border-radius: 12px;
                border-width: 3px;
                border-color: root.brand-green;
                visible: root.page-count > 0;
            }

            pbar := TouchArea {
                height: 32px; y: -10px;
                mouse-cursor: none;
                clicked => { root.progress-tap(pbar.mouse-x / pbar.width); }
            }
        }

        Text {
            text: root.status != ""
                  ? root.status
                  : ((root.playing || root.nav-recent || root.has-navigated)
                     ? ("Page " + (root.page + 1) + " of " + root.page-count)
                     : (root.play-enabled
? "Swipe down: menu - double-tap: play - swipe: pages"
                         : "Connect WiFi & Bluetooth to play - swipe down: menu"));
            color: root.text-primary;
            font-size: 22px;
            horizontal-alignment: center;
            vertical-alignment: center;
            y: 32px;
            x: 56px;
            width: root.width - 200px;
            wrap: no-wrap;
            overflow: elide;
            padding-left: 20px;
            padding-right: 20px;
            visible: !root.picker-active && root.page-count > 0;
        }

        // Same 76px circle as every header button.
        Rectangle {
            x: root.width - 99px;
            y: 8px;
            width: 76px;
            height: 76px;
            border-radius: 38px;
            background: !root.play-enabled ? root.brand-gray
                        : (root.playing ? root.brand-red : root.brand-green);
            visible: !root.picker-active && root.page-count > 0;
            pp-touch := TouchArea {
                clicked => {
                    if (root.play-enabled) { root.play-pause-toggle(); }
                }
            }

            Rectangle {
                visible: root.playing;
                x: 26px; y: 22px; width: 8px; height: 32px;
                background: #ffffff; border-radius: 2px;
            }
            Rectangle {
                visible: root.playing;
                x: 42px; y: 22px; width: 8px; height: 32px;
                background: #ffffff; border-radius: 2px;
            }

            // Play triangle as stacked rectangles: no Path in the software renderer.
            Rectangle { visible: !root.playing; x: 29px; y: 22px; width: 4px;  height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 26px; width: 10px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 30px; width: 16px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 34px; width: 22px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 38px; width: 22px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 42px; width: 16px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 46px; width: 10px; height: 4px; background: #ffffff; }
            Rectangle { visible: !root.playing; x: 29px; y: 50px; width: 4px;  height: 4px; background: #ffffff; }
        }
    }
}
