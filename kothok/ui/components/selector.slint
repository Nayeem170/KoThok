export component SelectorRow inherits HorizontalLayout {
    in property <string> label;
    in property <bool> on-state: false;
    in property <bool> connected: false;
    in property <bool> center-toggle: false;
    in property <color> brand-green: #006A4E;
    in property <color> brand-red: #F42A41;
    in property <color> bg-off: #1a1a1a;
    in property <color> bg-pressed: #555555;
    callback prev();
    callback next();
    callback toggle();

    // Off (black) -> connecting (red) -> connected (green).
    property <color> state-color:
        root.connected ? root.brand-green
        : root.on-state ? root.brand-red
        : root.bg-off;

    height: 52px;
    spacing: 10px;

    Rectangle {
        width: 64px; height: 52px;
        border-radius: 10px;
        background: prev-ta.pressed ? root.bg-pressed : root.state-color;
        Text {
            text: "<";
            color: #ffffff; font-size: 26px;
            horizontal-alignment: center; vertical-alignment: center;
        }
        prev-ta := TouchArea {
            clicked => { root.prev(); }
        }
    }

    Rectangle {
        height: 52px;
        border-radius: 10px;
        background: root.state-color;
        horizontal-stretch: 1;
        if root.center-toggle : TouchArea {
            clicked => { root.toggle(); }
        }
        Text {
            text: root.label;
            color: #ffffff; font-size: 22px;
            horizontal-alignment: center; vertical-alignment: center;
            overflow: elide;
        }
    }

    Rectangle {
        width: 64px; height: 52px;
        border-radius: 10px;
        background: next-ta.pressed ? root.bg-pressed : root.state-color;
        Text {
            text: ">";
            color: #ffffff; font-size: 26px;
            horizontal-alignment: center; vertical-alignment: center;
        }
        next-ta := TouchArea {
            clicked => { root.next(); }
        }
    }
}
