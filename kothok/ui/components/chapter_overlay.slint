import { ActionButton } from "button.slint";

export component ChapterOverlay inherits Rectangle {
    in-out property <bool> visible-flag: false;
    in-out property <int> chapter-preview-idx: -1;
    in-out property <int> chapter-pending: -1;
    in property <int> current-chapter-idx: 0;
    in property <color> text-primary: #111111;
    in property <color> text-secondary: #666666;
    in property <color> brand-red: #F42A41;
    in property <color> track-color: #d0d0d0;

    callback chapter-selected(int);
    callback close-to-book();

    visible: root.visible-flag;
    background: #ffffff;

    Rectangle {
        y: 0px; height: 80px; width: root.width;
        background: #ffffff;

        ActionButton {
            x: 18px; y: 16px;
            width: 48px; height: 48px;
            icon: @image-url("assets/back.svg");
            bg: root.brand-red;
            radius: 24px;
            clicked => { root.chapter-preview-idx = -1; root.chapter-pending = -1; root.visible-flag = false; }
        }

        Text {
            text: "Chapters";
            color: root.text-secondary; font-size: 22px; font-weight: 700;
            horizontal-alignment: center; vertical-alignment: center;
            x: 96px; width: root.width - 192px; height: 80px;
            overflow: elide;
        }

        ActionButton {
            x: root.width - 66px; y: 16px;
            width: 48px; height: 48px;
            icon: @image-url("assets/close.svg");
            bg: root.brand-red;
            radius: 24px;
            clicked => {
                root.chapter-preview-idx = -1;
                root.chapter-pending = -1;
                root.visible-flag = false;
                root.close-to-book();
            }
        }

        Rectangle {
            y: 79px; height: 1px; width: root.width;
            background: root.track-color;
        }
    }

    VerticalLayout {
        padding-left: 40px; padding-right: 40px;
        padding-top: 96px; padding-bottom: 36px;
        spacing: 16px;

        Rectangle {
            vertical-stretch: 1;
            background: transparent;
        }

        ActionButton {
            height: 84px;
            label: "Open";
            font-size: 32px;
            clicked => {
                root.chapter-selected(root.chapter-preview-idx >= 0 ? root.chapter-preview-idx : root.current-chapter-idx);
            }
        }
    }
}
